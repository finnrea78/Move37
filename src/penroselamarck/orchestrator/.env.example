# Optional language filter (empty = all)
ORCHESTRATOR_LANGUAGE=

# Number of unclassified exercises scanned each run
ORCHESTRATOR_CLASSIFY_LIMIT=100

# Optional comma-separated search queries to precompute each run
ORCHESTRATOR_SEARCH_QUERIES=medical interview,cardiology basics
ORCHESTRATOR_SEARCH_LIMIT=20

# Runtime logging / telemetry
LOG_LEVEL=INFO
OTEL_ENABLED=true
OTEL_SERVICE_NAME=penroselamarck-orchestrator
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_METRICS_EXPORT_INTERVAL_MS=5000
