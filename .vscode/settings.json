{
    "workbench.colorTheme": "Palenight (Mild Contrast)",
    "workbench.startupEditor": "none",
    "workbench.settings.editor": "json",
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.wrapTabs": false,
    "workbench.editor.tabActionCloseVisibility": false,
    "workbench.editor.closeOnFileDelete": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.tree.indent": 8,
    "window.commandCenter": false,
    "breadcrumbs.enabled": true,

    "editor.fontFamily": "'Source Code Pro', Consolas, 'Courier New', monospace",
    "editor.fontSize": 11,
    "editor.lineHeight": 20,
    "editor.letterSpacing": 0.8,
    "editor.fontLigatures": true,
    "editor.tabSize": 4,
    "editor.wordWrap": "off",
    "editor.renderWhitespace": "all",
    "editor.renderControlCharacters": true,
    "editor.smoothScrolling": true,
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.hideCursorInOverviewRuler": true,
    "editor.overviewRulerBorder": false,
    "editor.renderLineHighlight": "none",
    "editor.lineDecorationsWidth": 0,
    "editor.foldingImportsByDefault": false,
    "editor.showFoldingControls": "always",
    "editor.stickyScroll.enabled": false,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.minimap.scale": 3,
    "editor.minimap.side": "right",
    "editor.minimap.autohide": "mouseover",
    "editor.rulers": [
        { "column": 80, "color": "#0c2b0c" },
        { "column": 120, "color": "#161b22" }
    ],

    "terminal.integrated.fontFamily": "'Source Code Pro', Consolas, 'Courier New', monospace",
    "terminal.integrated.fontSize": 11,
    "terminal.integrated.lineHeight": 1.5,
    "terminal.integrated.letterSpacing": 1.0,
    "terminal.integrated.cursorStyle": "underline",
    "terminal.integrated.cursorWidth": 8,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyleInactive": "underline",
    "terminal.integrated.fastScrollSensitivity": 5,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.tabs.location": "left",
    "terminal.integrated.tabs.showActions": "never",
    "terminal.integrated.tabs.title": "${activeEditorShort}",

    "explorer.compactFolders": false,
    "explorer.decorations.badges": false,
    "explorer.sortOrder": "type",
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "*.scss": "${capture}.css",
        ".eslintrc.*": ".eslintignore, .editorconfig, .prettierrc",
        "appsettings.json": "appsettings.*.json"
    },
    "files.autoSave": "off",
    "files.trimTrailingWhitespace": true,
    "editor.trimAutoWhitespace": true,

    "search.showLineNumbers": true,
    "search.smartCase": true,
    "search.collapseResults": "alwaysExpand",
    "search.searchEditor.focusResultsOnSearch": true,
    "search.sortOrder": "type",

    "debug.console.fontFamily": "'Source Code Pro', Consolas, 'Courier New', monospace",
    "debug.console.fontSize": 11,
    "debug.console.lineHeight": 20,
    "debug.enableStatusBarColor": false,
    "debug.focusEditorOnBreak": true,
    "debug.focusWindowOnBreak": true,
    "debug.showInStatusBar": "always",
    "debug.toolBarLocation": "docked",
    "debug.showVariableTypes": true,

    "git.decorations.enabled": false,
    "gitlens.codeLens.enabled": false,
    "gitlens.graph.commitOrdering": "date",
    "gitlens.graph.minimap.enabled": true,
    "gitlens.graph.pullRequests.enabled": true,
    "scm.inputFontFamily": "'Source Code Pro', Consolas, 'Courier New', monospace",
    "scm.inputFontSize": 11,
    "scm.inputMinLineCount": 4,
    "scm.inputMaxLineCount": 10,
    "[scminput]": { "editor.wordWrap": "off" },

    "python.analysis.typeCheckingMode": "basic",
    "python.defaultInterpreterPath": "/usr/bin/python3",
    "python-envs.defaultEnvManager": "ms-python.python:system",
    "python-envs.pythonProjects": [],
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "[toml]": {
        "editor.formatOnSave": false
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
        "editor.formatOnSave": true,
        "editor.insertSpaces": true,
        "editor.tabSize": 2
    },
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    "shellformat.flag": "-i 4 -sr",
    "hadolint.hadolintPath": "hadolint",

    "chat.agent.maxRequests": 50,
    "chat.promptFilesLocations": {
        ".github/prompts/devcontainer": true
    },

    "files.exclude": {
        "**/.ruff_cache": true,
        "**/node_modules": true,
        "**/node_modules/**": true,
        "**/*.log": true,
        "**/.gitconfig": true,
        "**/.lesshst": true,
        "**/.npmrc": true,
        "**/.bash_history": true,
        "**/.sudo_as_admin_successful": true,
        "**/**.egg-info": true,
        "**/__pycache__": true,
        "**/dist": true,
        "**/.ssh": true,
        "**/.npm": true,
        "**/.local": true,
        "**/.gnupg": true,
        "**/.dotnet": true,
       "**/.docker/.token_seed": true,
       "**/.docker/.token_seed.lock": true,
        "**/.docker/buildx": true,
        "**/.config": true,
        "**/.cdk": true,
        "**/.cache": true,
        "**/.vscode-server": true,
        "**/cdk.out": true,
        "**/coverage": true,
        "**/.aws/cli": true,
        "**/.aws/sso": true,
        "**/.devcontainer/.*": true,
        "**/.kube": true,
        "**/.cdk.context.json": true,
        "**/.rediscli_history": true,
        "**/.pytest_cache": true,
        "**/.psql_history": true,
        "**/.python_history": true
    },
    "search.exclude": {
        "**/.ruff_cache": true,
        "**/node_modules": true,
        "**/node_modules/**": true,
        "**/*.log": true,
        "**/.gitconfig": true,
        "**/.lesshst": true,
        "**/.npmrc": true,
        "**/.bash_history": true,
        "**/.sudo_as_admin_successful": true,
        "**/**.egg-info": true,
        "**/__pycache__": true,
        "**/dist": true,
        "**/.ssh": true,
        "**/.npm": true,
        "**/.local": true,
        "**/.gnupg": true,
        "**/.dotnet": true,
       "**/.docker/.token_seed": true,
       "**/.docker/.token_seed.lock": true,
        "**/.docker/buildx": true,
        "**/.config": true,
        "**/.cdk": true,
        "**/.cache": true,
        "**/.vscode-server": true,
        "**/cdk.out": true,
        "**/coverage": true,
        "**/.aws/cli": true,
        "**/.aws/sso": true,
        "**/.devcontainer/.*": true,
        "**/.kube": true,
        "**/.cdk.context.json": true,
        "**/.rediscli_history": true,
        "**/.pytest_cache": true,
        "**/.psql_history": true,
        "**/.python_history": true
    },

    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "string.quoted.docstring.multi.python",
                    "string.quoted.docstring.multi.python punctuation.definition.string.begin.python",
                    "string.quoted.docstring.multi.python punctuation.definition.string.end.python",
                    "comment.block.documentation"
                ],
                "settings": {
                    "foreground": "#f0d37c"
                }
            }
        ]
    },
    "workbench.colorCustomizations": {
        "editor.background": "#1e1e1e",
        "terminal.background": "#0c2b0c",
        "sideBar.background": "#161b22",
        "sideBar.foreground": "#bdbdbd",
        "sideBarTitle.foreground": "#264f64",
        "sideBar.dropBackground": "#1e1e1e",
        "sideBarSectionHeader.background": "#161b22",
        "sideBarSectionHeader.border": "#161b22",
        "sideBarSectionHeader.foreground": "#264f64",
        "tab.activeBackground": "#0c2b0c",
        "tab.inactiveBackground": "#1e1e1e",
        "editorGroupHeader.tabsBackground": "#1e1e1e",
        "tab.activeBorder": "#1e1e1e",
        "tab.activeBorderTop": "#1e1e1e",
        "panel.background": "#1e1e1e",
        "panel.dropBorder": "#93268c",
        "panelTitleBadge.background": "#1e1e1e",
        "panelTitleBadge.foreground": "#1a5c1a",
        "panelSectionHeader.foreground": "#264f64",
        "panelTitle.activeBorder": "#1e1e1e",
        "panelTitle.inactiveForeground": "#1e1e1e",
        "panelTitle.activeForeground": "#1a5c1a",
        "statusBar.background": "#1e1e1e",
        "statusBarItem.remoteBackground": "#1e1e1e",
        "statusBarItem.remoteForeground": "#1a5c1a",
        "panelSectionHeader.background": "#283f91",
        "breadcrumb.foreground": "#1a5c1a",
        "editorWarning.foreground": "#1e1e1e",
        "editorWarning.background": "#d6c61740",
        "editorError.foreground": "#1e1e1e",
        "editorError.background": "#a3101089",
        "titleBar.activeForeground": "#1e1e1e",
        "titleBar.inactiveForeground": "#1e1e1e",
        "titleBar.activeBackground": "#1e1e1e",
        "titleBar.inactiveBackground": "#1e1e1e",
        "titleBar.foregroundHover": "#1a5c1a",
        "statusBar.foreground": "#1a5c1a",
        "activityBar.background": "#161b22",
        "activityBar.dropBorder": "#161b22",
        "activityBarBadge.background": "#161b22",
        "activityBarBadge.foreground": "#408d40",
        "activityBarTop.foreground": "#161b22",
        "activityBarTop.background": "#161b22",
        "activityBar.inactiveForeground": "#161b22",
        "activityBar.foreground": "#408d40",
        "activityBar.activeBorder": "#161b22",
        "activityBar.border": "#161b22",
        "sideBar.border": "#1e1e1e",
        "panel.border": "#1e1e1e",
        "statusBar.border": "#1e1e1e",
        "editorGroup.border": "#1e1e1e",
        "tab.border": "#1e1e1e",
        "editor.selectionBorder": "#1e1e1e",
        "window.activeBorder": "#1e1e1e",
        "window.inactiveBorder": "#1e1e1e",
        "contrastBorder": "#1e1e1e",
        "titleBar.border": "#1e1e1e",
        "editorGroupHeader.tabsBorder": "#1e1e1e",
        "editorGroupHeader.border": "#1e1e1e",
        "editorOverviewRuler.border": "#1e1e1e",
        "scrollbar.shadow": "#1e1e1e",
        "dropdown.border": "#1e1e1e",
        "scrollbarSlider.background": "#0c2b0c",
        "scrollbarSlider.hoverBackground": "#0c2b0c",
        "scrollbarSlider.activeBackground": "#408d40",
        "list.highlightForeground": "#6ca4f8",
        "editor.lineHighlightBorder": "#1e1e1e",
        "editor.selectionHighlightBorder": "#1e1e1e",
        "list.activeSelectionBackground": "#0c2b0c",
        "list.inactiveSelectionBackground": "#0c2b0c",
        "list.hoverBackground": "#408d40",
        "input.background": "#1e1e1e",
        "dropdown.background": "#1e1e1e",
        "quickInput.background": "#1e1e1e",
        "focusBorder": "#1e1e1e",
        "editorWidget.background": "#1e1e1e",
        "notifications.background": "#1e1e1e",
        "editor.lineNumbersBorder": "#1e1e1e",
        "editorWhitespace.foreground": "#0c2b0c",
        "editorLineNumber.foreground": "#1a5c1a",
        "editorLineNumber.activeForeground": "#408d40",
        "[Copilot Theme]": {}
    }
}
