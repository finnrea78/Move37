HOST_WORKSPACE=/home/$USER/penrose-lamarck
# Authorisation ################################################################
#
# We follow the standard MCP authorisation flow:
#
#   OAuth 2.1 with Authorization Code + PKCE
#
# The following variables are used for authorisation with Auth0.
# The MCP Resource Server is registered with audience https://penroselamarck/.
#
# Native Application
AUTH0_DOMAIN=dev-h6ida4cs1fkg6cfj.us.auth0.com
AUTH0_AUDIENCE=https://penroselamarck/
# Optional overrides (defaults are derived from AUTH0_DOMAIN)
AUTH0_ISSUER=https://dev-h6ida4cs1fkg6cfj.us.auth0.com/
AUTH0_JWKS_URL=https://dev-h6ida4cs1fkg6cfj.us.auth0.com/.well-known/jwks.json
MCP_RESOURCE_URLS=http://localhost:8080,http://penroselamarck-mcp:8080
AUTH0_ALGORITHMS=RS256
AUTH0_ROLES_CLAIM=permissions
AUTH0_CLOCK_SKEW_SECONDS=60
AUTH0_JWKS_CACHE_TTL_SECONDS=600
AUTH0_JWKS_TIMEOUT_SECONDS=5
AUTH0_CLIENT_APP_NAME=penrose-lamarck
AUTH0_CLIENT_APP_ID=PASTEHERE
AUTH0_CLIENT_APP_SECRET=PASTEHERE

# OAuth protected resource metadata
MCP_RESOURCE_URL=PASTEHERE
MCP_RESOURCE_URLS=http://localhost:8080,http://penroselamarck-mcp:8080




# Optional: a locally cached access token for VS Code MCP config examples.
AUTH0_ACCESS_TOKEN=
