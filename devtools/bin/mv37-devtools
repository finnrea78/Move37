#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
IMAGE_TAG="${MV37_DEVTOOLS_IMAGE:-mv37-devtools:local}"
DEFAULT_CONFIG="${MV37_DEVTOOLS_DEFAULT_CONFIG:-devtools/config/move37.repo.toml}"

if [ "$#" -eq 0 ]; then
  set -- bootstrap plan
fi

if ! command -v docker >/dev/null 2>&1; then
  echo "docker is required to run mv37-devtools" >&2
  exit 1
fi

NEEDS_GH_AUTH=1
case "${1:-}" in
  infra|help|--help)
    NEEDS_GH_AUTH=0
    ;;
esac

GITHUB_TOKEN=""
if [ "${NEEDS_GH_AUTH}" = "1" ]; then
  if ! command -v gh >/dev/null 2>&1; then
    echo "gh is required to run mv37-devtools repo/bootstrap commands" >&2
    exit 1
  fi

  if ! gh auth status >/dev/null 2>&1; then
    echo "gh auth is required to run mv37-devtools repo/bootstrap commands" >&2
    exit 1
  fi

  GITHUB_TOKEN="$(gh auth token)"
  if [ -z "${GITHUB_TOKEN}" ]; then
    echo "gh auth token returned an empty token" >&2
    exit 1
  fi
fi

if [ "${MV37_DEVTOOLS_REBUILD:-0}" = "1" ] || ! docker image inspect "${IMAGE_TAG}" >/dev/null 2>&1; then
  docker build -t "${IMAGE_TAG}" -f "${REPO_ROOT}/devtools/Dockerfile" "${REPO_ROOT}"
fi

docker_args=(
  run
  --rm
  -e "MV37_DEVTOOLS_DEFAULT_CONFIG=${DEFAULT_CONFIG}"
  -v "${REPO_ROOT}:/workspace"
  -w /workspace
)

if [ -n "${GITHUB_TOKEN}" ]; then
  docker_args+=(-e "GITHUB_TOKEN=${GITHUB_TOKEN}")
fi

for aws_var in \
  AWS_PROFILE \
  AWS_REGION \
  AWS_DEFAULT_REGION \
  AWS_ACCOUNT_ID \
  CDK_DEFAULT_ACCOUNT \
  CDK_DEFAULT_REGION \
  AWS_ACCESS_KEY_ID \
  AWS_SECRET_ACCESS_KEY \
  AWS_SESSION_TOKEN \
  AWS_ROLE_ARN \
  AWS_WEB_IDENTITY_TOKEN_FILE \
  MOVE37_DEPLOY_ENV \
  MOVE37_DEPLOY_BRANCH
do
  if [ -n "${!aws_var:-}" ]; then
    docker_args+=(-e "${aws_var}=${!aws_var}")
  fi
done

if [ -n "${HOME:-}" ] && [ -d "${HOME}/.aws" ]; then
  docker_args+=(-v "${HOME}/.aws:/root/.aws:ro")
fi

docker "${docker_args[@]}" "${IMAGE_TAG}" "$@"
